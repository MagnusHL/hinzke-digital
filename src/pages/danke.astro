---
import Layout from '../layouts/Layout.astro';
import CTAButton from '../components/CTAButton.astro';
---

<Layout title="Vielen Dank">
  <section class="flex min-h-[60vh] items-center py-20">
    <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mb-6">
        <svg class="mx-auto h-16 w-16 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-3xl font-bold text-gray-900">Vielen Dank für deine Buchung!</h1>
      <p class="mt-4 text-lg text-gray-600">
        Wir haben deine Bestellung erhalten und senden dir in Kürze eine Bestätigungsmail.
        Wir melden uns zeitnah, um die nächsten Schritte zu besprechen.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <CTAButton href="/">Zur Startseite</CTAButton>
        <CTAButton href="/kontakt" variant="secondary">Kontakt aufnehmen</CTAButton>
      </div>
    </div>
  </section>
</Layout>
