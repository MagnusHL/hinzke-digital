---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TechStackGrid from '../components/TechStackGrid.astro';
import CTAButton from '../components/CTAButton.astro';
---

<Layout title="Über mich" description="Magnus Hinzke -- Unternehmer aus Lübeck. 40+ Jahre Druckbranche, jetzt auch digital.">
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold text-gray-900">Magnus Hinzke</h1>
        <p class="mt-2 text-lg text-primary">Unternehmer, Digitalisierung & KI</p>
      </div>

      <div class="mx-auto mt-12 max-w-3xl space-y-6 text-gray-600">
        <p class="text-lg leading-relaxed">
          Seit über 40 Jahren führe ich mit der Volker Hinzke GmbH eine Druckerei in Lübeck.
          Was als klassischer Repro- und Druckbetrieb begann, hat sich über die Jahrzehnte weiterentwickelt:
          Variabler Datendruck, Medienproduktion, Textildruck und Werbetechnik gehören heute zum Kerngeschäft.
        </p>
        <p class="text-lg leading-relaxed">
          Zu unseren Kunden zählen unter anderem der VfB Lübeck, VfL Lübeck Schwartau und THW Kiel.
          Wir produzieren alles von personalisierten Druckprodukten über technische Zeichnungen bis hin zu 
          Textilveredelung und Beschriftungen.
        </p>
        <p class="text-lg leading-relaxed">
          Mit Hinzke Digital bringe ich die Erfahrung aus vier Jahrzehnten Unternehmertum zusammen mit 
          moderner Technologie. Kein Buzzword-Bingo, sondern erprobte Lösungen, die im Mittelstand funktionieren.
          Self-hosted, Open Source, datensouverän -- weil Unabhängigkeit zählt.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Tech-Stack"
        subtitle="Technologien und Tools, mit denen ich täglich arbeite"
      />
      <div class="mx-auto max-w-4xl">
        <TechStackGrid />
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900">Interesse geweckt?</h2>
      <p class="mx-auto mt-4 max-w-xl text-gray-600">
        Lassen Sie uns sprechen. Unverbindlich, direkt und auf Augenhöhe.
      </p>
      <div class="mt-8">
        <CTAButton href="/kontakt" size="lg">Kontakt aufnehmen</CTAButton>
      </div>
    </div>
  </section>
</Layout>
