---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ModuleCard from '../components/ModuleCard.astro';
import CTAButton from '../components/CTAButton.astro';
import { getCollection } from 'astro:content';

const modules = (await getCollection('module')).sort((a, b) => a.data.order - b.data.order);
const featuredModules = modules.slice(0, 4);
---

<Layout title="Weniger Handarbeit, mehr Ergebnis -- Hinzke Digital">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-gray-50 to-white py-20 md:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 md:grid-cols-2">
        <div>
          <h1 class="text-4xl font-bold tracking-tight text-gray-900 md:text-6xl">
            Weniger Handarbeit,<br />
            <span class="text-primary">mehr Ergebnis</span>
          </h1>
          <p class="mt-6 max-w-xl text-lg text-gray-600">
            KI-Module, Automatisierung und professionelle Webseiten -- speziell für den Mittelstand.
            Pragmatisch umgesetzt, self-hosted, DSGVO-konform.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <CTAButton href="/webseiten" size="lg">Webseiten-Pakete</CTAButton>
            <CTAButton href="/module" variant="secondary" size="lg">Module entdecken</CTAButton>
          </div>
        </div>
        <div class="relative">
          <img
            src="/images/hero-workspace.png"
            alt="Moderner Arbeitsplatz mit Laptop, Dashboard und Kaffee"
            class="rounded-2xl shadow-2xl"
            width="800"
            height="450"
            loading="eager"
          />
          <div class="absolute -inset-4 -z-10 rounded-3xl bg-primary/5"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- USPs -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Warum Hinzke Digital?"
        subtitle="Praxiserfahrung trifft moderne Technologie"
      />
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
          <div class="mb-3">
            <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-gray-900">KI-gestützt</h3>
          <p class="text-sm leading-relaxed text-gray-600">Modernste KI-Technologie für intelligente Automatisierung und smarte Workflows. <a href="/module" class="font-medium text-primary hover:underline">Entdecke unsere Module</a>.</p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
          <div class="mb-3">
            <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-gray-900">Self-hosted</h3>
          <p class="text-sm leading-relaxed text-gray-600">Deine Daten auf deiner Infrastruktur. Volle Kontrolle, DSGVO-konform, kein Vendor-Lock-in. <a href="/ueber-mich#tech-stack" class="font-medium text-primary hover:underline">Mehr zum Tech-Stack</a>.</p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
          <div class="mb-3">
            <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" /></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-gray-900">Individuell</h3>
          <p class="text-sm leading-relaxed text-gray-600">Keine Standardlösung von der Stange. Jedes Modul wird auf dein Unternehmen angepasst. <a href="/kontakt" class="font-medium text-primary hover:underline">Lass uns reden</a>.</p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
          <div class="mb-3">
            <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-gray-900">Aus der Praxis</h3>
          <p class="text-sm leading-relaxed text-gray-600">Digitalisierung mit Bodenhaftung statt Buzzword-Bingo. Gebaut von jemandem, der selbst Prozesse automatisiert. <a href="/ueber-mich" class="font-medium text-primary hover:underline">Über Magnus</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="border-y border-gray-100 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="mb-8 text-center text-sm font-medium uppercase tracking-wider text-gray-500">Vertrauen von Unternehmen aus Lübeck und Umgebung</p>
      <div class="flex flex-wrap items-center justify-center gap-12 opacity-60 grayscale">
        <span class="text-lg font-semibold text-gray-400">VfB Lübeck</span>
        <span class="text-lg font-semibold text-gray-400">VfL Lübeck-Schwartau</span>
        <span class="text-lg font-semibold text-gray-400">THW Kiel</span>
      </div>
    </div>
  </section>

  <!-- Webseiten Teaser -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Professionelle Webseiten"
        subtitle="Drei Pakete für jeden Bedarf -- von der einfachen Webpräsenz bis zum Full-Service-Paket"
      />
      <div class="text-center">
        <p class="mx-auto mb-8 max-w-2xl text-gray-600">
          Responsive, schnell, SEO-optimiert. Deine Webseite wird mit modernen Frameworks gebaut
          und auf deiner eigenen Infrastruktur gehostet.
        </p>
        <CTAButton href="/webseiten">Pakete ansehen</CTAButton>
      </div>
    </div>
  </section>

  <!-- Featured Module -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Digitale Module"
        subtitle="Fertige Bausteine für die Digitalisierung deines Unternehmens"
      />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {featuredModules.map((mod) => (
          <ModuleCard
            title={mod.data.title}
            description={mod.data.description}
            slug={mod.id}
            icon={mod.data.icon}
          />
        ))}
      </div>
      <div class="mt-12 text-center">
        <CTAButton href="/module" variant="secondary">Alle 14 Module ansehen</CTAButton>
      </div>
    </div>
  </section>

  <!-- Beliebte Kombinationen -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Beliebte Kombinationen"
        subtitle="Module, die zusammen besonders gut funktionieren"
      />
      <div class="grid gap-6 md:gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-gray-200 bg-white p-8">
          <h3 class="mb-3 text-xl font-bold text-gray-900">Kundenservice-Paket</h3>
          <p class="mb-6 text-sm text-gray-600">Schneller antworten, besser betreuen, Bewertungen im Griff -- dein Rundum-Paket für zufriedene Kunden.</p>
          <ul class="mb-6 space-y-2">
            <li><a href="/module/support-chat" class="text-sm font-medium text-primary hover:underline">Support-Chat</a></li>
            <li><a href="/module/ticket-system" class="text-sm font-medium text-primary hover:underline">Ticket-System</a></li>
            <li><a href="/module/bewertungen" class="text-sm font-medium text-primary hover:underline">Bewertungs-Management</a></li>
          </ul>
          <CTAButton href="/kontakt" variant="secondary" size="sm">Mehr erfahren</CTAButton>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-8">
          <h3 class="mb-3 text-xl font-bold text-gray-900">Büro-Autopilot</h3>
          <p class="mb-6 text-sm text-gray-600">Buchhaltung, E-Mails und Dokumente automatisiert verarbeiten -- weniger Verwaltung, mehr Zeit fürs Kerngeschäft.</p>
          <ul class="mb-6 space-y-2">
            <li><a href="/module/buchhaltung" class="text-sm font-medium text-primary hover:underline">Buchhaltung</a></li>
            <li><a href="/module/email-assistent" class="text-sm font-medium text-primary hover:underline">KI E-Mail Assistent</a></li>
            <li><a href="/module/dokumenten-ki" class="text-sm font-medium text-primary hover:underline">Dokumenten-KI</a></li>
          </ul>
          <CTAButton href="/kontakt" variant="secondary" size="sm">Mehr erfahren</CTAButton>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-8">
          <h3 class="mb-3 text-xl font-bold text-gray-900">Marketing-Boost</h3>
          <p class="mb-6 text-sm text-gray-600">Content erstellen, Leads qualifizieren und per Newsletter nachfassen -- Marketing auf Autopilot.</p>
          <ul class="mb-6 space-y-2">
            <li><a href="/module/social-media" class="text-sm font-medium text-primary hover:underline">Social Media Autopilot</a></li>
            <li><a href="/module/newsletter" class="text-sm font-medium text-primary hover:underline">Newsletter-System</a></li>
            <li><a href="/module/lead-qualifizierung" class="text-sm font-medium text-primary hover:underline">Lead-Qualifizierung</a></li>
          </ul>
          <CTAButton href="/kontakt" variant="secondary" size="sm">Mehr erfahren</CTAButton>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary py-20 text-white">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold md:text-4xl">Bereit für deinen nächsten Schritt?</h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-blue-100">
        Lass uns in einem unverbindlichen Gespräch herausfinden, welche digitalen Lösungen
        dein Unternehmen voranbringen.
      </p>
      <div class="mt-8">
        <a
          href="/kontakt"
          class="inline-flex items-center justify-center rounded-lg bg-white px-8 py-3 text-base font-semibold text-primary transition-colors hover:bg-blue-50"
        >
          Beratungsgespräch vereinbaren
        </a>
      </div>
    </div>
  </section>
</Layout>
