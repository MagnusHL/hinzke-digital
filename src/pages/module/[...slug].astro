---
import Layout from '../../layouts/Layout.astro';
import CTAButton from '../../components/CTAButton.astro';
import RelatedModules from '../../components/RelatedModules.astro';
import ModuleHero from '../../components/ModuleHero.astro';
import Highlights from '../../components/Highlights.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import ContentSection from '../../components/ContentSection.astro';
import StatsCounter from '../../components/StatsCounter.astro';
import { getCollection } from 'astro:content';
import { getModuleImage } from '../../lib/images';

export async function getStaticPaths() {
  const modules = await getCollection('module');
  return modules.map((mod) => ({
    params: { slug: mod.id },
    props: { mod, allModules: modules },
  }));
}

const { mod, allModules } = Astro.props;

// Related Modules auflösen
const relatedModules = mod.data.relatedModules
  ? allModules.filter((m: any) => mod.data.relatedModules!.includes(m.id))
  : [];

// FAQ Schema generieren
const faqSchema = mod.data.faq && mod.data.faq.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": mod.data.faq.map((item: { question: string; answer: string }) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer,
        },
      })),
    }
  : null;

// Service Schema
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": mod.data.title,
  "description": mod.data.description,
  "provider": {
    "@type": "ProfessionalService",
    "name": "Hinzke Digital",
    "url": "https://hinzke.digital",
  },
};

const structuredData = faqSchema
  ? [serviceSchema, faqSchema]
  : serviceSchema;

const breadcrumbItems = [
  { label: 'Startseite', href: '/' },
  { label: 'Module', href: '/module' },
  { label: mod.data.title },
];
---

<Layout
  title={mod.data.title}
  description={mod.data.description}
  canonicalUrl={`https://hinzke.digital/module/${mod.id}`}
  structuredData={structuredData}
>
  <article>

    <!-- 1. Hero -->
    <ModuleHero
      title={mod.data.title}
      description={mod.data.description}
      icon={mod.data.icon}
      techStack={mod.data.techStack}
      breadcrumbItems={breadcrumbItems}
    />

    <!-- 2. Highlights -->
    <Highlights items={mod.data.highlights} />

    <!-- 3. Prozess-Schritte -->
    <ProcessSteps steps={mod.data.steps} />

    <!-- 4. Problem-Sektion -->
    <ContentSection
      heading={mod.data.problem.heading}
      text={mod.data.problem.text}
      imageSrc={getModuleImage(mod.id, 'problem')}
      imageAlt={`${mod.data.title} -- Problemdarstellung`}
      bgClass="bg-gray-50"
    />

    <!-- 5. Stats Counter -->
    <StatsCounter />

    <!-- 6. Lösungs-Sektion -->
    <ContentSection
      heading={mod.data.solution.heading}
      text={mod.data.solution.text}
      imageSrc={getModuleImage(mod.id, 'solution')}
      imageAlt={`${mod.data.title} -- Lösung`}
      reversed
    />

    <!-- 7. Benefits -->
    <section class="py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="mb-8 text-3xl font-bold text-gray-900">Deine Vorteile</h2>
        <ul class="grid gap-4 sm:grid-cols-2">
          {mod.data.benefits.map((benefit: string) => (
            <li class="flex items-start gap-3 rounded-lg bg-gray-50 p-4">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">{benefit}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- 8. FAQ Accordion -->
    {mod.data.faq && mod.data.faq.length > 0 && (
      <section class="py-16">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
          <h2 class="mb-8 text-center text-3xl font-bold text-gray-900">Häufige Fragen</h2>
          <div class="space-y-3">
            {mod.data.faq.map((item: { question: string; answer: string }) => (
              <details class="group rounded-xl border border-gray-200 bg-white">
                <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-left font-semibold text-gray-900 [&::-webkit-details-marker]:hidden">
                  <span>{item.question}</span>
                  <svg class="h-5 w-5 flex-shrink-0 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-6 pb-4 text-gray-600 leading-relaxed">
                  {item.answer}
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- 9. CTA Section -->
    <section class="bg-gray-50 py-16">
      <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900">Bereit für den nächsten Schritt?</h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
          Lass uns in einem unverbindlichen Gespräch klären, wie {mod.data.title} dein Unternehmen voranbringt.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <CTAButton href="/kontakt" size="lg">Beratungsgespräch buchen</CTAButton>
          <CTAButton href="/kontakt" variant="secondary" size="lg">Individuell anfragen</CTAButton>
        </div>
      </div>
    </section>

    <!-- 10. Related Modules -->
    <div class="mx-auto max-w-6xl px-4 pb-16 sm:px-6 lg:px-8">
      <RelatedModules modules={relatedModules} />
    </div>

  </article>
</Layout>
