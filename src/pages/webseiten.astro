---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CTAButton from '../components/CTAButton.astro';
import PaketCard from '../components/PaketCard.astro';
import Highlights from '../components/Highlights.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ContentSection from '../components/ContentSection.astro';
import StatsCounter from '../components/StatsCounter.astro';

const pakete = [
  {
    name: 'Starter',
    price: 'ab 990',
    highlighted: false,
    href: '#starter',
    features: [
      'Bis zu 5 Seiten',
      'Responsive Design',
      'Kontaktformular',
      'SEO-Grundlagen',
      'SSL-Zertifikat',
      '1 Korrekturschleife',
    ],
  },
  {
    name: 'Business',
    price: 'ab 2.490',
    highlighted: true,
    href: '#business',
    features: [
      'Bis zu 10 Seiten',
      'CMS für eigene Pflege',
      'Blog-Funktion',
      'Analytics-Integration',
      'Newsletter-Anbindung',
      'SEO-Optimierung',
      '3 Korrekturschleifen',
    ],
  },
  {
    name: 'Premium',
    price: 'ab 4.990',
    highlighted: false,
    href: '#premium',
    features: [
      'Unbegrenzte Seiten',
      'E-Commerce-Integration',
      'KI-Features (Chatbot, Suche)',
      'Priority Support',
      'Performance-Optimierung',
      'Schulung für dein Team',
      'Laufende Betreuung',
    ],
  },
];

const highlights = [
  {
    icon: 'check',
    title: 'Alles aus einer Hand',
    text: 'Design, Entwicklung, Hosting und Support von einem Ansprechpartner. Keine Abstimmung zwischen fünf Dienstleistern.',
  },
  {
    icon: 'check',
    title: 'SEO von Tag 1',
    text: 'Jede Seite wird suchmaschinenoptimiert gebaut, nicht nachträglich gefrickelt. Damit du von Anfang an gefunden wirst.',
  },
  {
    icon: 'check',
    title: 'DSGVO-konform',
    text: 'Hosting auf eigener Infrastruktur in Deutschland, keine US-Cloud-Abhängigkeit. Datenschutz ohne Kompromisse.',
  },
];

const steps = [
  {
    title: 'Gespräch buchen',
    description: 'Wir klären Ziele, Zielgruppe und Umfang in einem kurzen Call.',
  },
  {
    title: 'Konzept & Design',
    description: 'Du bekommst einen Entwurf zur Freigabe, bevor eine Zeile Code geschrieben wird.',
  },
  {
    title: 'Umsetzung',
    description: 'Wir bauen deine Seite mit modernem Tech-Stack, schnell und wartbar.',
  },
  {
    title: 'Launch & Betreuung',
    description: 'Go-Live, SEO-Check und auf Wunsch laufende Betreuung.',
  },
];

const faq = [
  { q: 'Wie lange dauert die Umsetzung?', a: 'Starter: 1-2 Wochen. Business: 2-4 Wochen. Premium: 4-8 Wochen. Abhängig von deinen Inhalten und Rückmeldungen.' },
  { q: 'Was passiert nach der Fertigstellung?', a: 'Du kannst die Seite selbst pflegen (Business/Premium) oder beauftragst uns mit laufender Betreuung. Hosting und SSL sind inklusive.' },
  { q: 'Kann ich später upgraden?', a: 'Selbstverständlich. Wir bauen modular auf, sodass ein Upgrade jederzeit möglich ist, ohne von vorne anfangen zu müssen.' },
  { q: 'Welche Technologien werden eingesetzt?', a: 'Wir nutzen Astro, Tailwind CSS und TypeScript. Schnell, modern, wartbar. Hosting auf deiner eigenen Infrastruktur oder bei uns.' },
  { q: 'Brauche ich technische Vorkenntnisse?', a: 'Nein. Bei Business und Premium bekommst du ein CMS, mit dem du Inhalte ganz ohne Programmierkenntnisse pflegen kannst. Beim Premium-Paket ist eine Schulung inklusive.' },
  { q: 'Ist Hosting im Preis enthalten?', a: 'Ja. Wir hosten deine Webseite auf unserer eigenen Infrastruktur -- schnell, sicher und DSGVO-konform. Keine versteckten Kosten.' },
  { q: 'Kann ich meine Domain mitbringen?', a: 'Klar. Du kannst deine bestehende Domain verwenden oder wir registrieren eine neue für dich. Der Umzug ist unkompliziert.' },
  { q: 'Was passiert, wenn ich Hilfe brauche?', a: 'Du erreichst uns direkt per Mail oder über das Kontaktformular. Beim Premium-Paket hast du Priority Support mit schnelleren Reaktionszeiten.' },
];

const breadcrumbItems = [
  { label: 'Startseite', href: '/' },
  { label: 'Webseiten-Pakete' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
};
---

<Layout
  title="Webseiten-Pakete"
  description="Professionelle Webseiten für KMU. Drei Pakete: Starter, Business, Premium. Modern, schnell, SEO-optimiert."
  structuredData={faqSchema}
>
  <article>

    <!-- 1. Hero -->
    <section class="bg-gray-50 py-16 md:py-20">
      <div class="mx-auto max-w-6xl px-4">
        <Breadcrumb items={breadcrumbItems} />

        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight">Webseiten-Pakete</h1>
        <p class="mt-4 max-w-3xl text-lg text-gray-600 leading-relaxed">
          Professionelle Webseiten für jedes Budget. Modern gebaut, schnell geladen, SEO-optimiert -- von der Visitenkarte im Netz bis zur Full-Service-Lösung.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <CTAButton href="#pakete" variant="primary" size="lg">Pakete ansehen</CTAButton>
          <CTAButton href="/kontakt#beratung" variant="secondary" size="lg">Beratung buchen</CTAButton>
        </div>
      </div>
    </section>

    <!-- 2. Paket-Cards -->
    <section id="pakete" class="py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto grid max-w-5xl gap-6 lg:gap-8 lg:grid-cols-3">
          {pakete.map((paket) => (
            <PaketCard
              name={paket.name}
              price={paket.price}
              features={paket.features}
              highlighted={paket.highlighted}
              href={paket.href}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- 3. Vergleichstabelle -->
    <section class="pb-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="overflow-hidden rounded-xl border border-gray-200">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs sm:text-sm">
              <thead>
                <tr class="sticky top-0 bg-gray-50">
                  <th class="px-3 py-4 font-semibold text-gray-900 sm:px-6">Feature</th>
                  <th class="px-3 py-4 text-center font-semibold text-gray-900 sm:px-6">Starter</th>
                  <th class="px-3 py-4 text-center font-semibold text-primary sm:px-6">Business</th>
                  <th class="px-3 py-4 text-center font-semibold text-gray-900 sm:px-6">Premium</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr>
                  <td class="px-3 py-3 text-gray-700 sm:px-6">Seiten</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Bis zu 5</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Bis zu 10</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Unbegrenzt</td>
                </tr>
                <tr class="bg-gray-50/50">
                  <td class="px-3 py-3 text-gray-700 sm:px-6">Design</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Responsive</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Responsive + CMS</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Responsive + CMS + Custom</td>
                </tr>
                <tr>
                  <td class="px-3 py-3 text-gray-700 sm:px-6">SEO</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Grundlagen</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Optimierung</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Full SEO + Performance</td>
                </tr>
                <tr class="bg-gray-50/50">
                  <td class="px-3 py-3 text-gray-700 sm:px-6">Support</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">1 Korrektur</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">3 Korrekturen</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Priority + Schulung</td>
                </tr>
                <tr>
                  <td class="px-3 py-3 text-gray-700 sm:px-6">Extras</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Kontaktformular, SSL</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Blog, Analytics, Newsletter</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">E-Commerce, KI-Features, Betreuung</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. Highlights -->
    <Highlights items={highlights} />

    <!-- 5. Prozess-Schritte -->
    <ProcessSteps steps={steps} />

    <!-- 6. Problem-Sektion -->
    <ContentSection
      heading="Deine aktuelle Website bremst dich aus"
      text="Veraltetes Design, langsame Ladezeiten, nicht mobiloptimiert -- potenzielle Kunden springen ab, bevor sie dein Angebot sehen. Jede Sekunde Ladezeit kostet dich Conversions. Und Google straft langsame Seiten in den Rankings ab."
      imageSrc="/images/webseiten-problem.png"
      imageAlt="Veraltete Website mit schlechtem Design und langsamen Ladezeiten"
      bgClass="bg-gray-50"
    />

    <!-- 7. Stats Counter -->
    <StatsCounter />

    <!-- 8. Solution-Sektion -->
    <ContentSection
      heading="Eine Website, die für dich arbeitet"
      text="Schnell, modern, SEO-optimiert -- deine neue Webseite lädt in unter einer Sekunde, sieht auf jedem Gerät perfekt aus und wird von Google belohnt. Mit einem CMS kannst du Inhalte selbst pflegen, ohne Entwickler fragen zu müssen."
      imageSrc="/images/webseiten-solution.png"
      imageAlt="Moderne, schnelle Website mit cleaner UI und Top-PageSpeed-Score"
      reversed
    />

    <!-- 9. Cross-Links zu Modulen -->
    <section class="py-16">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-xl bg-gray-50 p-8 text-center">
          <h3 class="mb-4 text-xl font-bold text-gray-900">Ergänze dein Paket mit digitalen Modulen</h3>
          <p class="mb-6 text-gray-600">
            Deine Webseite ist erst der Anfang. Kombiniere sie mit unseren <a href="/module" class="font-medium text-primary hover:underline">14 digitalen Modulen</a> für maximale Wirkung.
          </p>
          <div class="space-y-2 text-sm text-gray-600">
            <p><strong>Premium:</strong> Perfekt kombinierbar mit unserem <a href="/module/support-chat" class="font-medium text-primary hover:underline">Support-Chat</a> für automatisierten Kundenservice.</p>
            <p><strong>Business:</strong> Ergänze mit einem <a href="/module/newsletter" class="font-medium text-primary hover:underline">Newsletter-System</a> für regelmäßige Kundenkommunikation.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 10. FAQ -->
    <section class="py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="mb-8 text-center text-3xl font-bold text-gray-900">Häufige Fragen</h2>
        <div class="space-y-3">
          {faq.map((item) => (
            <details class="group rounded-xl border border-gray-200 bg-white">
              <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-left font-semibold text-gray-900 [&::-webkit-details-marker]:hidden">
                <span>{item.q}</span>
                <svg class="h-5 w-5 flex-shrink-0 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-6 pb-4 text-gray-600 leading-relaxed">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- 11. CTA Section -->
    <section class="bg-gray-50 py-16">
      <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900">Bereit für deine neue Website?</h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
          Lass uns in einem kurzen Gespräch klären, welches Paket zu dir passt -- unverbindlich und kostenlos.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <CTAButton href="/kontakt#beratung" size="lg">Beratungsgespräch buchen</CTAButton>
          <CTAButton href="/kontakt" variant="secondary" size="lg">Individuell anfragen</CTAButton>
        </div>
      </div>
    </section>

  </article>
</Layout>
