---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CTAButton from '../components/CTAButton.astro';
import PaketCard from '../components/PaketCard.astro';
import Highlights from '../components/Highlights.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ContentSection from '../components/ContentSection.astro';
import StatsCounter from '../components/StatsCounter.astro';
import webseitenProblem from '../assets/images/webseiten-problem.png';
import webseitenSolution from '../assets/images/webseiten-solution.png';

const pakete = [
  {
    name: 'Web Start',
    price: '1.690',
    highlighted: false,
    href: '/kontakt#beratung',
    subtitle: 'Die ideale Basis für den Einstieg',
    timeline: 'Realisierung: ca. 14 Tage',
    features: [
      'Initiales Briefing zur Ausrichtung',
      'Hosting-Infrastruktur + SSL',
      'Responsive Design',
      'Logo-Integration + farbliche Anpassung',
      'Bis zu 4 Unterseiten + Impressum/Datenschutz',
      'Basis Keyword-Recherche (3–5 Keywords)',
      'OnPage-Optimierung (Title, Headlines)',
      'XML-Sitemap + robots.txt',
    ],
  },
  {
    name: 'Web Business',
    price: '2.890',
    highlighted: true,
    href: '/kontakt#beratung',
    subtitle: 'Das Rundum-Paket für wachsende Unternehmen',
    timeline: 'Realisierung: ca. 30 Tage',
    features: [
      'Initiales Briefing zur Ausrichtung',
      'Hosting-Infrastruktur + SSL',
      'Responsive Design + erweiterte Mobiloptimierung',
      'Corporate Design (Logo, Farbschema, Stil)',
      'Usability + Conversion-Optimierung',
      'Bis zu 8 Unterseiten + Impressum/Datenschutz',
      'Keyword-Recherche mit Report',
      'Mitbewerberanalyse (Top 3 Konkurrenten)',
      'OnPage-Optimierung (Title, Descriptions, Headlines, Verlinkungen)',
      'Schema.org Markup',
      'XML-Sitemap + robots.txt',
      'LLMS-Datei für KI-Indizierung',
    ],
  },
  {
    name: 'Web Pro',
    price: 'ab 3.990',
    highlighted: false,
    href: '/kontakt#beratung',
    subtitle: 'Maximale Sichtbarkeit und individuelle Lösung',
    timeline: 'Realisierung: nach Absprache',
    features: [
      'Briefing + Content-Strategie',
      'Hosting-Infrastruktur + SSL',
      'Individuelles Design-System',
      'Responsive Design + erweiterte Mobiloptimierung',
      'Usability + Conversion-Optimierung',
      'Individuelle Seitenanzahl + Impressum/Datenschutz',
      'Umfangreiche Keyword-Recherche inkl. Long-Tail mit Report',
      'Mitbewerberanalyse (Top 5 Konkurrenten)',
      'Bildoptimierung für Ladezeiten',
      'OnPage-Optimierung (Title, Descriptions, Headlines, Verlinkungen)',
      'Schema.org Markup',
      'XML-Sitemap + robots.txt',
      'LLMS-Datei für KI-Indizierung',
      'AIO-Optimierung (ChatGPT, Claude, Perplexity)',
    ],
  },
];

const highlights = [
  {
    icon: 'check',
    title: 'Erst verstehen, dann bauen',
    text: 'Wir starten mit einem ausführlichen Briefing. Was sind deine Ziele? Wen willst du erreichen? Was macht der Wettbewerb? Daraus entsteht deine Webseite.',
  },
  {
    icon: 'check',
    title: 'SEO + KI-Sichtbarkeit',
    text: 'Keyword-Recherche, Schema.org, LLMS-Datei für KI-Indizierung. Damit du nicht nur bei Google, sondern auch bei ChatGPT und Co. gefunden wirst.',
  },
  {
    icon: 'check',
    title: 'Mehr als eine Webseite',
    text: 'Deine Seite ist der Anfang. Mit unseren digitalen Modulen erweiterst du sie um Support-Chat, Newsletter, Buchungssystem und mehr.',
  },
];

const steps = [
  {
    title: 'Erstgespräch',
    description: 'Wir lernen dein Unternehmen kennen: Ziele, Zielgruppe, Wettbewerb. Kein Verkaufsgespräch, sondern echte Bestandsaufnahme.',
  },
  {
    title: 'Analyse & Konzept',
    description: 'Mitbewerberanalyse, Keyword-Recherche und ein Konzept, das auf deinen tatsächlichen Bedarf zugeschnitten ist.',
  },
  {
    title: 'Umsetzung',
    description: 'Design und Entwicklung mit regelmäßigem Feedback. Du siehst früh, wohin es geht.',
  },
  {
    title: 'Launch & Weiterentwicklung',
    description: 'Go-Live mit SEO-Check. Und danach? Schau dir unsere Module an -- vom Newsletter bis zum KI-Chatbot.',
  },
];

const faq = [
  { q: 'Wie lange dauert die Umsetzung?', a: 'Web Start: ca. 14 Tage. Web Business: ca. 30 Tage. Web Pro: nach individueller Absprache. Die Timeline hängt auch von deinen Rückmeldungen und Inhalten ab.' },
  { q: 'Was passiert im Erstgespräch?', a: 'Wir hören zu und stellen Fragen: Was sind deine Ziele? Wen willst du erreichen? Was macht der Wettbewerb? Kein Verkaufsgespräch -- sondern eine echte Bestandsaufnahme, aus der dein Konzept entsteht.' },
  { q: 'Welche Technologien werden eingesetzt?', a: 'Wir setzen auf ein professionelles CMS und moderne Webtechnologien -- schnell, sicher und wartbar. Die Technik wählen wir passend zu deinen Anforderungen.' },
  { q: 'Was ist KI-Optimierung / AIO?', a: 'Neben Google nutzen immer mehr Menschen KI-Assistenten wie ChatGPT, Claude oder Perplexity, um Dienstleister zu finden. Mit einer LLMS-Datei und AIO-Optimierung sorgen wir dafür, dass auch diese Systeme deine Inhalte kennen und empfehlen.' },
  { q: 'Brauche ich technische Vorkenntnisse?', a: 'Nein. Du bekommst ein CMS, mit dem du Inhalte ganz ohne Programmierkenntnisse pflegen kannst. Bei Fragen sind wir per Mail erreichbar.' },
  { q: 'Gibt es ein Hosting-Angebot?', a: 'Ja. Wir bieten zwei Pakete: Basic (59 EUR netto/Monat) mit Hosting, SSL, Backups, 3 Domains und E-Mail-Support. Oder Wartung (99 EUR netto/Monat) mit zusätzlichen WordPress-Updates, Sicherheits-Monitoring, 30 Min Änderungen/Monat und Telefon-Support. Alternativ kannst du dein eigenes Hosting nutzen.' },
  { q: 'Kann ich meine Domain mitbringen?', a: 'Klar. Du kannst deine bestehende Domain verwenden oder wir registrieren eine neue für dich. Der Umzug ist unkompliziert.' },
  { q: 'Kann ich später upgraden?', a: 'Selbstverständlich. Wir bauen modular auf, sodass ein Upgrade jederzeit möglich ist, ohne von vorne anfangen zu müssen.' },
  { q: 'Was passiert nach der Fertigstellung?', a: 'Du kannst die Seite selbst pflegen oder unser Hosting-Paket mit laufender Wartung nutzen. Und mit unseren digitalen Modulen erweiterst du deine Webseite um weitere Funktionen -- vom Newsletter bis zum KI-Chatbot.' },
];

const breadcrumbItems = [
  { label: 'Startseite', href: '/' },
  { label: 'Webseiten-Pakete' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
};

const offerSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Webseiten-Pakete",
  "description": "Professionelle Webseiten für KMU -- drei Pakete für jeden Bedarf.",
  "provider": {
    "@type": "Organization",
    "@id": "https://hinzke.digital/#organization"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Webseiten-Pakete",
    "itemListElement": [
      {
        "@type": "Offer",
        "name": "Web Start",
        "description": "Basis-Paket: bis zu 4 Unterseiten, Responsive Design, Basis-SEO. Realisierung ca. 14 Tage.",
        "price": "1690",
        "priceCurrency": "EUR",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "1690",
          "priceCurrency": "EUR",
          "valueAddedTaxIncluded": false
        }
      },
      {
        "@type": "Offer",
        "name": "Web Business",
        "description": "Rundum-Paket: bis zu 8 Unterseiten, Corporate Design, erweiterte SEO, Schema.org, LLMS-Datei. Realisierung ca. 30 Tage.",
        "price": "2890",
        "priceCurrency": "EUR",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "2890",
          "priceCurrency": "EUR",
          "valueAddedTaxIncluded": false
        }
      },
      {
        "@type": "Offer",
        "name": "Web Pro",
        "description": "Premium-Paket: individuelles Design-System, Full SEO + AIO-Optimierung, individuelle Seitenanzahl.",
        "price": "3990",
        "priceCurrency": "EUR",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "3990",
          "priceCurrency": "EUR",
          "valueAddedTaxIncluded": false
        }
      }
    ]
  }
};
---

<Layout
  title="Webseiten-Pakete"
  description="Professionelle Webseiten für KMU. Drei Pakete: Web Start, Web Business, Web Pro. SEO-optimiert und sichtbar für Google und KI."
  structuredData={[faqSchema, offerSchema]}
>
  <article>

    <!-- 1. Hero -->
    <section class="bg-gray-50 py-16 md:py-20">
      <div class="mx-auto max-w-6xl px-4">
        <Breadcrumb items={breadcrumbItems} />

        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight">Webseiten-Pakete</h1>
        <p class="mt-4 max-w-3xl text-lg text-gray-600 leading-relaxed">
          Wir bauen nicht einfach eine Website -- wir schauen erst, was du wirklich brauchst. Im Erstgespräch klären wir Ziele, Zielgruppe und Wettbewerb. Dann entsteht eine Seite, die nicht nur gut aussieht, sondern gefunden wird -- von Google und von KI.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <CTAButton href="/kontakt#beratung" variant="primary" size="lg">Beratungsgespräch buchen</CTAButton>
          <CTAButton href="#pakete" variant="secondary" size="lg">Pakete ansehen</CTAButton>
        </div>
      </div>
    </section>

    <!-- 2. Paket-Cards -->
    <section id="pakete" class="py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto grid max-w-5xl gap-6 lg:gap-8 lg:grid-cols-3">
          {pakete.map((paket) => (
            <PaketCard
              name={paket.name}
              price={paket.price}
              features={paket.features}
              highlighted={paket.highlighted}
              href={paket.href}
              subtitle={paket.subtitle}
              timeline={paket.timeline}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- 3. Vergleichstabelle -->
    <section class="pb-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="overflow-hidden rounded-xl border border-gray-200">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs sm:text-sm">
              <thead>
                <tr class="sticky top-0 bg-gray-50">
                  <th class="px-3 py-4 font-semibold text-gray-900 sm:px-6">Feature</th>
                  <th class="px-3 py-4 text-center font-semibold text-gray-900 sm:px-6">Web Start</th>
                  <th class="px-3 py-4 text-center font-semibold text-primary sm:px-6">Web Business</th>
                  <th class="px-3 py-4 text-center font-semibold text-gray-900 sm:px-6">Web Pro</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr>
                  <td class="px-3 py-3 text-gray-700 sm:px-6">Unterseiten</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Bis zu 4</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Bis zu 8</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Individuell</td>
                </tr>
                <tr class="bg-gray-50/50">
                  <td class="px-3 py-3 text-gray-700 sm:px-6">Design</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Responsive + Farbanpassung</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Corporate Design + Conversion</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Individuelles Design-System</td>
                </tr>
                <tr>
                  <td class="px-3 py-3 text-gray-700 sm:px-6">SEO</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Basis (Title, Headlines)</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Erweitert + Mitbewerber + Schema.org</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Full SEO + AIO-Optimierung</td>
                </tr>
                <tr class="bg-gray-50/50">
                  <td class="px-3 py-3 text-gray-700 sm:px-6">KI-Optimierung</td>
                  <td class="px-3 py-3 text-center text-gray-400 sm:px-6">--</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">LLMS-Datei</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">LLMS + AIO</td>
                </tr>
                <tr>
                  <td class="px-3 py-3 text-gray-700 sm:px-6">Keyword-Analyse</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">3–5 Keywords</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Recherche + Report</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Long-Tail + Report</td>
                </tr>
                <tr class="bg-gray-50/50">
                  <td class="px-3 py-3 text-gray-700 sm:px-6">Realisierung</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">ca. 14 Tage</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">ca. 30 Tage</td>
                  <td class="px-3 py-3 text-center text-gray-600 sm:px-6">Nach Absprache</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. Hosting-Pakete -->
    <section id="hosting" class="pb-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="mb-2 text-2xl font-bold text-gray-900">Hosting & Wartung</h2>
        <p class="mb-8 text-gray-500">Optional buchbar -- kein Pflicht-Add-on. DSGVO-konformes Hosting in Deutschland.</p>

        <div class="grid gap-6 lg:grid-cols-2">

          <!-- Basic -->
          <div class="rounded-xl border border-gray-200 bg-gray-50 p-6 sm:p-8">
            <h3 class="text-lg font-bold text-gray-900">Basic</h3>
            <div class="mt-2 flex items-baseline">
              <span class="text-3xl font-bold text-gray-900">59</span>
              <span class="ml-1 text-sm text-gray-500">EUR netto/Monat</span>
            </div>
            <p class="mt-1 text-xs text-gray-400">70,21 EUR brutto</p>
            <ul class="mt-6 space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Webhosting (Webspace, SSL, E-Mail-Postfächer)
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Tägliche Backups
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Let's Encrypt SSL automatisch
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                3 Domains inklusive, jede weitere +3 EUR/Monat
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                E-Mail-Support
              </li>
            </ul>
            <a href="/kontakt#beratung" class="mt-6 inline-block rounded-lg border-2 border-primary px-6 py-2 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white">
              Beratung anfragen
            </a>
          </div>

          <!-- Wartung -->
          <div class="rounded-xl border-2 border-primary bg-white p-6 shadow-lg sm:p-8">
            <div class="flex items-center gap-2">
              <h3 class="text-lg font-bold text-gray-900">Wartung</h3>
              <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-semibold text-primary">Empfohlen</span>
            </div>
            <div class="mt-2 flex items-baseline">
              <span class="text-3xl font-bold text-gray-900">99</span>
              <span class="ml-1 text-sm text-gray-500">EUR netto/Monat</span>
            </div>
            <p class="mt-1 text-xs text-gray-400">117,81 EUR brutto</p>
            <ul class="mt-6 space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Alles aus Basic
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Monatliche WordPress-Updates (Core, Plugins, Theme)
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Sicherheits-Monitoring
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                30 Min Änderungen/Monat inklusive
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Darüber hinaus 80 EUR/Std netto
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Telefonischer Support
              </li>
            </ul>
            <a href="/kontakt#beratung" class="mt-6 inline-block rounded-lg bg-primary px-6 py-2 text-sm font-semibold text-white transition-colors hover:bg-primary/90">
              Beratung anfragen
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- 5. Highlights -->
    <Highlights items={highlights} />

    <!-- 6. Prozess-Schritte -->
    <ProcessSteps steps={steps} />

    <!-- 7. Problem-Sektion -->
    <ContentSection
      heading="Deine aktuelle Website bremst dich aus"
      text="Veraltetes Design, langsame Ladezeiten, nicht mobiloptimiert -- potenzielle Kunden springen ab, bevor sie dein Angebot sehen. Jede Sekunde Ladezeit kostet dich Conversions. Und Google straft langsame Seiten in den Rankings ab."
      imageSrc={webseitenProblem}
      imageAlt="Veraltete Website mit schlechtem Design und langsamen Ladezeiten"
      bgClass="bg-gray-50"
    />

    <!-- 8. Stats Counter -->
    <StatsCounter />

    <!-- 9. Solution-Sektion -->
    <ContentSection
      heading="Eine Website, die für dich arbeitet"
      text="Schnell, modern, SEO-optimiert -- deine neue Webseite lädt in unter einer Sekunde, sieht auf jedem Gerät perfekt aus und wird von Google belohnt. Mit einem CMS kannst du Inhalte selbst pflegen, ohne Entwickler fragen zu müssen."
      imageSrc={webseitenSolution}
      imageAlt="Moderne, schnelle Website mit cleaner UI und Top-PageSpeed-Score"
      reversed
    />

    <!-- 10. Cross-Links zu Modulen -->
    <section class="py-16">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-xl bg-gray-50 p-8 text-center">
          <h3 class="mb-4 text-xl font-bold text-gray-900">Die Webseite ist der erste Schritt</h3>
          <p class="mb-6 text-gray-600">
            Viele unserer Kunden erweitern ihre Webseite mit unseren <a href="/module" class="font-medium text-primary hover:underline">digitalen Modulen</a>: Support-Chat für automatisierten Service, Newsletter-System für Kundenbindung, Bewertungs-Management für Google Reviews. Alles aus einer Hand.
          </p>
          <div class="space-y-2 text-sm text-gray-600">
            <p><strong>Web Business + Newsletter</strong> = regelmäßige <a href="/module/newsletter" class="font-medium text-primary hover:underline">Kundenkommunikation</a></p>
            <p><strong>Web Pro + Support-Chat</strong> = <a href="/module/support-chat" class="font-medium text-primary hover:underline">24/7 erreichbar</a></p>
          </div>
        </div>
      </div>
    </section>

    <!-- 11. FAQ -->
    <section class="py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="mb-8 text-center text-3xl font-bold text-gray-900">Häufige Fragen</h2>
        <div class="space-y-3">
          {faq.map((item) => (
            <details class="group rounded-xl border border-gray-200 bg-white">
              <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-left font-semibold text-gray-900 [&::-webkit-details-marker]:hidden">
                <span>{item.q}</span>
                <svg class="h-5 w-5 flex-shrink-0 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-6 pb-4 text-gray-600 leading-relaxed">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- 12. CTA Section -->
