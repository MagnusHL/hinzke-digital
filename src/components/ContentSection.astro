---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  heading: string;
  text: string;
  imageSrc: ImageMetadata;
  imageAlt: string;
  reversed?: boolean;
  bgClass?: string;
}

const { heading, text, imageSrc, imageAlt, reversed = false, bgClass = '' } = Astro.props;
---

<section class:list={['py-16', bgClass]}>
  <div class="mx-auto max-w-6xl px-4">
    <div class:list={[
      'grid items-center gap-12 md:grid-cols-2',
      reversed && 'md:[&>:first-child]:order-2',
    ]}>
      <div>
        <Image
          src={imageSrc}
          alt={imageAlt}
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 100vw, 50vw"
          format="webp"
          class="w-full rounded-xl object-cover shadow-lg aspect-video"
          loading="lazy"
        />
      </div>
      <div>
        <h2 class="mb-4 text-3xl font-bold text-gray-900">{heading}</h2>
        <p class="text-lg leading-relaxed text-gray-600">{text}</p>
      </div>
    </div>
  </div>
</section>
