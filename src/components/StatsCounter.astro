---
const stats = [
  { value: '14', label: 'fertige Module' },
  { value: '100%', label: 'Open Source Stack' },
  { value: '100%', label: 'DSGVO-konform' },
];
---

<section class="bg-primary py-16">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid gap-8 text-center md:grid-cols-3">
      {stats.map((stat) => (
        <div>
          <div class="text-4xl font-bold text-white md:text-5xl">{stat.value}</div>
          <div class="mt-2 text-sm text-white/80 md:text-base">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
