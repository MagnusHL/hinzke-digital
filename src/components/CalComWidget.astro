---
interface Props {
  baseUrl?: string;
  calLink?: string;
  layout?: 'month_view' | 'week_view' | 'column_view';
}

const {
  baseUrl = import.meta.env.CALCOM_BASE_URL,
  calLink = import.meta.env.CALCOM_LINK,
  layout = 'month_view',
} = Astro.props;

const isConfigured = baseUrl && calLink;
---

{isConfigured ? (
  <div>
    <h3 class="mb-6 text-xl font-semibold text-gray-900">Beratungsgespräch buchen</h3>
    <div id="cal-embed" style="width:100%;height:100%;overflow:scroll"></div>
    <script
      type="text/javascript"
      data-base-url={baseUrl}
      data-cal-link={calLink}
      data-layout={layout}
    >
      (function () {
        const script = document.currentScript;
        const baseUrl = script?.getAttribute("data-base-url");
        const calLink = script?.getAttribute("data-cal-link");
        const layout = script?.getAttribute("data-layout");

        const s = document.createElement("script");
        s.type = "text/javascript";
        s.src = baseUrl + "/embed/embed.js";
        s.async = true;
        s.onload = function () {
          // @ts-ignore
          Cal("init", { origin: baseUrl });
          // @ts-ignore
          Cal("inline", {
            elementOrSelector: "#cal-embed",
            calLink: calLink,
            layout: layout,
          });
          // @ts-ignore
          Cal("ui", {
            styles: { branding: { brandColor: "#137EDE" } },
            hideEventTypeDetails: false,
            layout: layout,
          });
        };
        document.head.appendChild(s);
      })();
    </script>
  </div>
) : (
  <div>
    <h3 class="mb-6 text-xl font-semibold text-gray-900">Beratungsgespräch buchen</h3>
    <div class="flex items-center justify-center rounded-xl border-2 border-dashed border-gray-300 p-12 text-center">
      <div>
        <p class="text-gray-500">Buchungswidget wird eingerichtet</p>
        <p class="mt-2 text-sm text-gray-400">
          In der Zwischenzeit erreichst du uns über das Kontaktformular.
        </p>
      </div>
    </div>
  </div>
)}
