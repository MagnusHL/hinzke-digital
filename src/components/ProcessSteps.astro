---
interface Props {
  steps: { title: string; description: string }[];
}

const { steps } = Astro.props;
const gridCols = steps.length === 3 ? 'lg:grid-cols-3' : 'lg:grid-cols-4';
---

<section class="py-16">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="mb-12 text-center text-3xl font-bold text-gray-900">So funktioniert's</h2>

    <div class:list={['grid gap-8 md:grid-cols-2', gridCols]}>
      {steps.map((step, index) => (
        <div class="relative flex flex-col items-center text-center">
          {index < steps.length - 1 && (
            <div class="absolute left-1/2 top-6 hidden h-0.5 w-full bg-gray-200 lg:block" />
          )}

          <div class="relative z-10 mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary text-xl font-bold text-white">
            {index + 1}
          </div>
          <h3 class="mb-2 text-lg font-semibold text-gray-900">{step.title}</h3>
          <p class="text-sm leading-relaxed text-gray-600">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
