---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  structuredData?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description = 'Digitale Produkte & Beratung von Magnus Hinzke. Webseiten, KI-Module und Automatisierung für den Mittelstand.',
  ogImage = '/og-default.png',
  canonicalUrl,
  structuredData,
  noindex = false,
} = Astro.props;

const resolvedCanonical = canonicalUrl || Astro.url.href;
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;

const businessSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": "https://hinzke.digital/#organization",
  "name": "Hinzke Digital",
  "legalName": "Volker Hinzke GmbH",
  "description": "Digitale Produkte & Beratung -- Webseiten, KI-Module und Automatisierung für den Mittelstand.",
  "url": "https://hinzke.digital",
  "logo": {
    "@type": "ImageObject",
    "url": "https://hinzke.digital/favicon.svg"
  },
  "image": "https://hinzke.digital/og-default.png",
  "telephone": "+494517995701",
  "email": "info@hinzke.de",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Kanalstraße 62",
    "postalCode": "23552",
    "addressLocality": "Lübeck",
    "addressRegion": "Schleswig-Holstein",
    "addressCountry": "DE"
  },
  "founder": {
    "@type": "Person",
    "@id": "https://hinzke.digital/ueber-mich#person",
    "name": "Magnus Hinzke"
  },
  "foundingDate": "1984",
  "taxID": "DE 135 086 257",
  "sameAs": [
    "https://www.linkedin.com/in/mhinzke/",
    "https://hinzke.de"
  ],
  "knowsAbout": ["KI-Automatisierung", "Webentwicklung", "Digitalisierung", "Self-Hosting"],
  "areaServed": {
    "@type": "Country",
    "name": "DE"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+494517995701",
    "email": "info@hinzke.de",
    "contactType": "customer service",
    "availableLanguage": "German"
  }
};

const allStructuredData = structuredData
  ? Array.isArray(structuredData)
    ? [businessSchema, ...structuredData]
    : [businessSchema, structuredData]
  : [businessSchema];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <title>{title} | Hinzke Digital</title>

    <link rel="canonical" href={resolvedCanonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Lokale Fonts -->
    <link rel="preload" href="/fonts/inter-latin-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-600.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-700.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Hinzke Digital`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:site_name" content="Hinzke Digital" />
    <meta property="og:image" content={resolvedOgImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Hinzke Digital`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Structured Data -->
    {allStructuredData.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}

    <!-- Matomo -->
    <script is:inline>
      var _paq = window._paq = window._paq || [];
      _paq.push(['trackPageView']);
      _paq.push(['enableLinkTracking']);
      (function() {
        var u="https://analytics.hinzke.de/";
        _paq.push(['setTrackerUrl', u+'matomo.php']);
        _paq.push(['setSiteId', '3']);
        var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
        g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
